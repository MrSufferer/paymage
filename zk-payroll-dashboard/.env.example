# Stellar network — TESTNET by default. Set to PUBLIC for mainnet.
NEXT_PUBLIC_STELLAR_NETWORK=TESTNET
NEXT_PUBLIC_HORIZON_URL=https://horizon-testnet.stellar.org
NEXT_PUBLIC_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# Latest testnet deployment (see deployments/testnet/deployments.json line 6).
# Override with mainnet contract IDs when promoting to PUBLIC.
NEXT_PUBLIC_PAYROLL_CONTRACT=CDSODUB6ZYOB5VZ4GV6MD2NAZ3RA3KZ73RVOBNZMFVXOO7CLLYWTUXNF
NEXT_PUBLIC_VERIFIER_CONTRACT=CCSE6A4JH4KDWE63XMJ62LZBJTKJY4AEY3Q6FIACTKXZMNAX2NA7HRI6
NEXT_PUBLIC_WITHDRAW_VERIFIER_CONTRACT=CCARTGQLYGE2TCFFGPNC2B4IXUZJV4Y5QZWNHX4CXEREDLVIB3XYY5DH
NEXT_PUBLIC_PAYROLL_TOKEN=CDLZFC3SYJYDZT7K67VZ75HPJVIEUVNIXF47ZG2FB2RMQQVU2HHGCYSC

# ZK engine: "mock" (browser dev, no real Groth16) or "real" (snarkjs + WASM prover).
NEXT_PUBLIC_ZK_ENGINE=mock

# Pinata IPFS — required for encrypted salary blob storage on run_payroll.
# Get a key at https://app.pinata.cloud/keys. When omitted, uploadToIpfs falls
# back to a deterministic demo CID (smoke-test only — on-chain run_payroll will
# still receive the CID, but the blob won't be retrievable from real IPFS).
NEXT_PUBLIC_PINATA_API_KEY=
NEXT_PUBLIC_IPFS_GATEWAY=https://gateway.pinata.cloud

# Server-only secrets (do NOT prefix with NEXT_PUBLIC_).
# SESSION_SECRET must be ≥ 32 characters. Generate with:
#   openssl rand -base64 48
SESSION_SECRET=your-secret-key-at-least-32-characters-long

# Stellar G... address that may take admin actions (e.g. set_employee_root, set_budget_cap).
# For the current testnet deployer, see deployments/testnet/deployments.json "deployer".
ADMIN_PUBLIC_KEY=GBBTKIOKPCGILWKYJASL7LL3TSITQMOVTYOL3Q5KG3Y4L7KY4BIXXXJI